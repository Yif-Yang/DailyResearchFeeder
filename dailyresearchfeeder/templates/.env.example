# LLM provider
LLM_PROVIDER=copilot_cli
COPILOT_COMMAND=copilot

# Uncomment and fill these if you use Azure OpenAI instead.
# LLM_PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4
# AZURE_OPENAI_API_KEY=

# Uncomment and fill these if you use OpenAI instead.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Email provider
EMAIL_PROVIDER=file

# Uncomment these for real email delivery.
# EMAIL_TO=your-email@example.com
# EMAIL_FROM=Daily Research Feeder <your-email@example.com>

# Gmail SMTP example
# EMAIL_PROVIDER=gmail_smtp
# GMAIL_SMTP_USERNAME=your-account@gmail.com
# GMAIL_SMTP_PASSWORD=your-16-char-app-password

# Generic SMTP example
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_STARTTLS=true
# SMTP_USERNAME=your-username
# SMTP_PASSWORD=your-password

# Resend example
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
